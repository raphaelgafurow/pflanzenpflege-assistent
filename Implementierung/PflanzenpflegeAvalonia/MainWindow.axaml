<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:CompileBindings="False"
        mc:Ignorable="d"
        x:Class="PflanzenpflegeAvalonia.MainWindow"
        Width="1366"
        Height="768"
        MinWidth="1020"
        MinHeight="620"
        Title="Übersicht - Pflanzenpflege-Assistent">
    <Grid Margin="16" RowDefinitions="Auto,*,Auto" RowSpacing="10">
        <Menu Grid.Row="0">
            <MenuItem Header="_Datei">
                <MenuItem Header="Übersicht" x:Name="MenuUebersicht" />
                <MenuItem Header="Pflanze anlegen" x:Name="MenuPflanzeAnlegen" />
                <MenuItem Header="Pflanze löschen" x:Name="MenuPflanzeLoeschen" />
                <MenuItem Header="Regel ändern/hinzufügen" x:Name="MenuRegelBearbeiten" />
                <MenuItem Header="Einträge ändern/hinzufügen" x:Name="MenuEintraege" />
                <Separator />
                <MenuItem Header="Beenden" x:Name="MenuBeenden" />
            </MenuItem>
            <MenuItem Header="_Ansicht">
                <MenuItem Header="Aktualisieren" x:Name="MenuAktualisieren" />
            </MenuItem>
        </Menu>

        <TabControl x:Name="MainTabs" Grid.Row="1">
            <TabItem Header="Übersicht">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                        <TextBlock Grid.Row="0"
                                   Text="Pflanzenübersicht"
                                   FontSize="58"
                                   FontWeight="SemiBold"
                                   Margin="2,0,0,8" />

                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <TextBox x:Name="SuchTextBox"
                                     Grid.Column="0"
                                     Watermark="Suche nach Name, Art oder Standort..."
                                     Height="34" />
                            <Button x:Name="SucheButton" Grid.Column="1" Content="Suchen" />
                            <Button x:Name="SucheZuruecksetzenButton" Grid.Column="2" Content="Zurücksetzen" />
                        </Grid>

                        <Grid Grid.Row="2" ColumnDefinitions="*,260" ColumnSpacing="14">
                            <DataGrid x:Name="PflanzenDataGrid"
                                      Grid.Column="0"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      Height="290"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Art" Binding="{Binding Art}" Width="*" />
                                    <DataGridTextColumn Header="Standort" Binding="{Binding Standort}" Width="*" />
                                    <DataGridTextColumn Header="Nächste Pflege" Binding="{Binding NaechstePflege}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Column="1" Spacing="12" VerticalAlignment="Top">
                                <Button x:Name="BtnPflanzeAnlegen" Content="Pflanze anlegen" />
                                <Button x:Name="BtnPflanzeLoeschen" Content="Pflanze löschen" />
                                <Button x:Name="BtnRegelBearbeiten" Content="Regel ändern/hinzufügen" />
                                <Button x:Name="BtnEintraegeBearbeiten" Content="Einträge ändern/hinzufügen" />
                                <Button x:Name="BtnBeenden" Content="Beenden" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Grid.Row="3"
                                   x:Name="AusgewaehltText"
                                   Text="Ausgewählt: -"
                                   FontSize="42"
                                   FontWeight="Medium" />

                        <Grid Grid.Row="4" ColumnDefinitions="*,320" ColumnSpacing="14">
                            <DataGrid x:Name="RegelnDataGrid"
                                      Grid.Column="0"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      Height="200"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Typ" Binding="{Binding Typ}" Width="*" />
                                    <DataGridTextColumn Header="Intervall" Binding="{Binding Intervall}" Width="*" />
                                    <DataGridTextColumn Header="Startdatum" Binding="{Binding Startdatum}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Column="1" Spacing="12" VerticalAlignment="Top">
                                <Border BorderThickness="1" Padding="14" Height="140">
                                    <Grid ColumnDefinitions="1.35*,1*">
                                        <TextBlock Grid.Column="0"
                                                   Text="Nächste&#10;fällige Pflege:"
                                                   FontSize="22"
                                                   FontWeight="Medium"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   x:Name="NaechstePflegeText"
                                                   Text="-"
                                                   FontSize="22"
                                                   FontWeight="Medium"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Button x:Name="BtnRegelLoeschen" Content="Regel löschen" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Pflanze anlegen">
                <Grid Margin="8" ColumnDefinitions="1.2*,1.8*,1*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="18" RowSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name *" FontSize="20" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TabNameBox" Height="34" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Art *" FontSize="20" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TabArtBox" Height="34" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Standort *" FontSize="20" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TabStandortBox" Height="34" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Kaufdatum *" FontSize="20" VerticalAlignment="Center" />
                    <DatePicker Grid.Row="3" Grid.Column="1" x:Name="TabKaufdatumPicker" Height="34" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Notizen" FontSize="20" VerticalAlignment="Top" />
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TabNotizenBox" Height="170" AcceptsReturn="True" TextWrapping="Wrap" />

                    <StackPanel Grid.Row="0" Grid.RowSpan="5" Grid.Column="2" Spacing="12" VerticalAlignment="Top">
                        <Button x:Name="TabPflanzeSpeichernButton" Content="Speichern" />
                        <Button x:Name="TabPflanzeZuruecksetzenButton" Content="Zurücksetzen" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Regel ändern/hinzufügen">
                <Grid Margin="8" ColumnDefinitions="1.2*,1.8*,1*" RowDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="18" RowSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" FontSize="20" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TabRegelNameText" FontSize="20" VerticalAlignment="Center" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Typ *" FontSize="20" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="TabRegelTypComboBox" Height="34" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Intervall Tage *" FontSize="20" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TabRegelIntervallBox" Height="34" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Startdatum *" FontSize="20" VerticalAlignment="Center" />
                    <DatePicker Grid.Row="3" Grid.Column="1" x:Name="TabRegelStartdatumPicker" Height="34" />

                    <StackPanel Grid.Row="0" Grid.RowSpan="4" Grid.Column="2" Spacing="12" VerticalAlignment="Top">
                        <Button x:Name="TabRegelSpeichernButton" Content="Speichern" />
                        <Button x:Name="TabRegelNeuButton" Content="Neue Regel" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Einträge ändern/hinzufügen">
                <Grid Margin="8" RowDefinitions="Auto,Auto,Auto,*" ColumnDefinitions="*">
                    <TextBlock Grid.Row="0" x:Name="TabEintraegeNameText" FontSize="32" FontWeight="SemiBold" />

                    <Grid Grid.Row="1" ColumnDefinitions="*,260" ColumnSpacing="14" Margin="0,10,0,0">
                        <DataGrid x:Name="TabEintraegeDataGrid"
                                  Grid.Column="0"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  IsReadOnly="True"
                                  Height="230"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Datum" Binding="{Binding Datum}" Width="*" />
                                <DataGridTextColumn Header="Typ" Binding="{Binding Typ}" Width="*" />
                                <DataGridTextColumn Header="Menge (Optional)" Binding="{Binding Menge}" Width="*" />
                                <DataGridTextColumn Header="Notiz (Optional)" Binding="{Binding Notiz}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Top">
                            <Button x:Name="TabEintragAendernButton" Content="Eintrag ändern" />
                            <Button x:Name="TabEintragLoeschenButton" Content="Eintrag löschen" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="Eintrag hinzufügen" FontSize="32" FontWeight="SemiBold" Margin="0,14,0,8" />

                    <Grid Grid.Row="3" ColumnDefinitions="1.2*,2.2*,260" RowDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="18" RowSpacing="10">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Typ *" FontSize="20" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="TabEintragTypComboBox" Height="34" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Datum *" FontSize="20" VerticalAlignment="Center" />
                        <DatePicker Grid.Row="1" Grid.Column="1" x:Name="TabEintragDatumPicker" Height="34" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Menge (optional)" FontSize="20" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TabEintragMengeBox" Height="70" AcceptsReturn="True" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Notiz (optional)" FontSize="20" VerticalAlignment="Center" />
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TabEintragNotizBox" Height="70" AcceptsReturn="True" TextWrapping="Wrap" />

                        <StackPanel Grid.Row="0" Grid.RowSpan="4" Grid.Column="2" Spacing="10" VerticalAlignment="Top">
                            <Button x:Name="TabEintragHinzufuegenButton" Content="Eintrag hinzufügen" />
                            <Button x:Name="TabEintragZuruecksetzenButton" Content="Zurücksetzen" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2" x:Name="StatusText" Text="Bereit." FontStyle="Italic" />
    </Grid>
</Window>
